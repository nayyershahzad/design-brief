{
  "theme": {
    "extend": {
      "fontFamily": {
        "sans": [
          "Inter",
          "ui-sans-serif",
          "system-ui",
          "sans-serif"
        ],
        "mono": [
          "IBM Plex Mono",
          "ui-monospace",
          "monospace"
        ]
      },
      "borderRadius": {
        "DEFAULT": "8px",
        "lg": "12px"
      },
      "borderWidth": {
        "hairline": "1px"
      },
      "transitionDuration": {
        "fast": "120ms",
        "DEFAULT": "220ms"
      },
      "transitionTimingFunction": {
        "standard": "cubic-bezier(0.2, 0, 0, 1)",
        "entrance": "cubic-bezier(0.16, 1, 0.3, 1)"
      },
      "colors": {
        "accent": {
          "DEFAULT": "#0CA678",
          "foreground": "#FFFFFF",
          "hover": "#12B886",
          "muted": "#E6FCF5"
        },
        "success": "#0CA678",
        "danger": "#E03131",
        "warning": "#F59F00"
      }
    }
  }
}
